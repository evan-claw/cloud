{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "llm-gateway",
  "account_id": "e115e769bcdd4c3d66af59d3332cb394",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "dev": {
    "port": 8787,
    "local_protocol": "http",
    "ip": "0.0.0.0",
  },
  "observability": {
    "enabled": true,
  },
  "logpush": true,
  "placement": {
    "mode": "smart",
  },
  "env": {
    "dev": {
      "name": "llm-gateway-dev",
      "workers_dev": true,
    },
  },
}
